# Generated outputs (temporary, can be regenerated)
code/*.html
code/plots/
code/execution*.log
code/pipeline*.log
code/__pycache__/

# Temporary files
*.tmp
*.temp
*.log
.ipynb_checkpoints/

# OS-specific
.DS_Store
Thumbs.db
.env
.env.local

# Project-specific
node_modules/
.cache/

# Keep documentation and source code in repo
!README.md
!*.py
!requirements.txt
!data/*.csv
!litterature/*.pdf
